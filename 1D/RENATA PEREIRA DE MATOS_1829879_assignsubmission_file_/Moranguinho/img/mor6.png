@charset "utf-8";

.gb_0a:not(.gb_Fd) { font: 13px / 27px Roboto, RobotoDraft, Arial, sans-ser=
if; z-index: 986; }

@-webkit-keyframes gb__a {=20
  0% { opacity: 0; }
  50% { opacity: 1; }
}

@keyframes gb__a {=20
  0% { opacity: 0; }
  50% { opacity: 1; }
}

a.gb_W { border: none; color: rgb(66, 133, 244); cursor: default; font-weig=
ht: bold; outline: none; position: relative; text-align: center; text-decor=
ation: none; text-transform: uppercase; white-space: nowrap; user-select: n=
one; }

a.gb_W:hover::after, a.gb_W:focus::after { background-color: rgba(0, 0, 0, =
0.12); content: ""; height: 100%; left: 0px; position: absolute; top: 0px; =
width: 100%; }

a.gb_W:hover, a.gb_W:focus { text-decoration: none; }

a.gb_W:active { background-color: rgba(153, 153, 153, 0.4); text-decoration=
: none; }

a.gb_X { background-color: rgb(66, 133, 244); color: rgb(255, 255, 255); }

a.gb_X:active { background-color: rgb(0, 67, 178); }

.gb_Z { box-shadow: rgba(0, 0, 0, 0.16) 0px 1px 1px; }

.gb_W, .gb_X, .gb_0, .gb_1 { display: inline-block; line-height: 28px; padd=
ing: 0px 12px; border-radius: 2px; }

.gb_0 { background: rgb(248, 248, 248); border: 1px solid rgb(198, 198, 198=
); }

.gb_1 { background: rgb(248, 248, 248); }

.gb_0, #gb a.gb_0.gb_0, .gb_1 { color: rgb(102, 102, 102); cursor: default;=
 text-decoration: none; }

#gb a.gb_1.gb_1 { cursor: default; text-decoration: none; }

.gb_1 { border: 1px solid rgb(66, 133, 244); font-weight: bold; outline: no=
ne; background: -webkit-linear-gradient(top, rgb(67, 135, 253), rgb(70, 131=
, 234)); }

#gb a.gb_1.gb_1 { color: rgb(255, 255, 255); }

.gb_1:hover { box-shadow: rgba(0, 0, 0, 0.15) 0px 1px 0px; }

.gb_1:active { box-shadow: rgba(0, 0, 0, 0.15) 0px 2px 0px inset; backgroun=
d: -webkit-linear-gradient(top, rgb(60, 122, 228), rgb(63, 118, 211)); }

#gb .gb_3 { background: rgb(255, 255, 255); border: 1px solid rgb(218, 220,=
 224); color: rgb(26, 115, 232); display: inline-block; text-decoration: no=
ne; }

#gb .gb_3:hover { background: rgb(248, 251, 255); border-color: rgb(218, 22=
0, 224); color: rgb(23, 78, 166); }

#gb .gb_3:focus { background: rgb(244, 248, 255); border-color: rgb(23, 78,=
 166); color: rgb(23, 78, 166); }

#gb .gb_3:active, #gb .gb_3:focus:active { background: rgb(236, 243, 254); =
color: rgb(23, 78, 166); }

#gb .gb_3.gb_4 { background: transparent; border: 1px solid rgb(95, 99, 104=
); color: rgb(138, 180, 248); text-decoration: none; }

